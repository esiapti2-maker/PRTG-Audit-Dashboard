# ── Credenciales del sitio principal ─────────────────────────────────────────
# Copia este archivo a .env y rellena tus valores.
# El .env NUNCA debe subirse al repositorio (está en .gitignore).

PRTG_HOST=https://prtg.tuempresa.com
PRTG_USER=admin
PRTG_SITE_NAME=Principal

# Usa passhash (más seguro) o password — no ambos
PRTG_PASSHASH=
PRTG_PASSWORD=

# ── Sitio DR / secundario (opcional) ─────────────────────────────────────────
# PRTG_HOST_DR=https://prtg-dr.tuempresa.com
# PRTG_USER_DR=admin
# PRTG_SITE_NAME_DR=DR
# PRTG_PASSHASH_DR=

# ── Opciones de exportación ───────────────────────────────────────────────────
PRTG_OUTPUT_DIR=reports
PRTG_LOG_LEVEL=INFO

# Desactivar verificación SSL si tienes certificado autofirmado
# PRTG_NO_VERIFY_SSL=true
