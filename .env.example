# PRTG Audit Dashboard — Variables de entorno
# Copia este archivo como .env y completa tus valores
# NUNCA subas el archivo .env al repositorio

# Sitio principal
PRTG_HOST=https://prtg.miempresa.com
PRTG_USER=admin
PRTG_PASSHASH=   # Obtener desde: Setup → My Account → Passhash

# Sitio secundario / DR (opcional)
PRTG_HOST_DR=https://prtg-dr.miempresa.com
PRTG_USER_DR=auditor
PRTG_PASSHASH_DR=
