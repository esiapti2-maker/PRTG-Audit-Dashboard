# ── PRTG Audit Dashboard — Variables de entorno ───────────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.

# ── Proxy / API server ────────────────────────────────────────────────────────
PROXY_HOST=0.0.0.0
PROXY_PORT=5000
PROXY_DEBUG=false
SECRET_KEY=cambia-esto-en-produccion

# Orígenes permitidos para CORS (separados por coma)
# En desarrollo: *
# En producción: https://tudominio.com
CORS_ORIGINS=*

# ── PRTG — Instancia por defecto ─────────────────────────────────────────────
# Si no se envían en el body del request, el proxy usa estas variables.
PRTG_HOST=https://prtg.tuempresa.com
PRTG_USER=auditor
PRTG_PASSHASH=1234567890  # Setup > My Account > Passhash
PRTG_VERIFY_SSL=false

# ── Exportación CSV ───────────────────────────────────────────────────────────
EXPORT_DIR=./reportes
