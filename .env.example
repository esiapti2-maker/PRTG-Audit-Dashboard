# PRTG Audit Dashboard — Variables de entorno
# Copia este archivo como .env y completa tus valores
# NUNCA subas el archivo .env al repositorio

# ── Sitio principal ───────────────────────────────────────
PRTG_HOST=https://prtg.miempresa.com
PRTG_USER=admin
PRTG_PASSHASH=        # Setup → My Account → Passhash
# PRTG_PASSWORD=      # alternativa (menos seguro)
PRTG_SITE_NAME=Principal

# ── Sitio secundario / DR (opcional) ─────────────────────
PRTG_HOST_DR=https://prtg-dr.miempresa.com
PRTG_USER_DR=auditor
PRTG_PASSHASH_DR=
PRTG_SITE_NAME_DR=DR

# ── Opciones generales ────────────────────────────────────
PRTG_OUTPUT_DIR=reports
PRTG_NO_VERIFY_SSL=false    # true solo en entornos con cert autofirmado
PRTG_LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR
